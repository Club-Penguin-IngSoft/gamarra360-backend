# ============================================================
# Gamarra 360° — Variables de entorno para producción (EC2)
# EC2 IP pública: 54.80.119.80  |  Dominio: gamarra360.duckdns.org
#
# PLANTILLA — NO poner secretos reales aquí (este archivo va a git).
# Los valores reales viven en el .env del servidor (gitignored) y en
# application.properties (gitignored).
#
# Pasos:
#   1. Copiar a /opt/gamarra360/.env
#   2. Completar los valores reales
#   3. El servicio systemd carga este archivo con EnvironmentFile=
# ============================================================

# Base de datos (AWS RDS)
SPRING_DATASOURCE_URL=jdbc:mysql://<host-rds>:3306/gamarra360?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=<usuario-rds>
SPRING_DATASOURCE_PASSWORD=<password-rds>

# JWT — usar una clave larga y aleatoria en produccion
JWT_SECRET=<clave-secreta-minimo-32-caracteres>

# Stripe
STRIPE_SECRET_KEY=sk_test_<tu-clave-secreta-stripe>
STRIPE_WEBHOOK_SECRET=whsec_<tu-webhook-secret>
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_<tu-webhook-secret-connect>

# URL del frontend — usada en redirects de Stripe Connect (OAuth de comerciantes)
APP_FRONTEND_URL=https://gamarra360.duckdns.org

# Google OAuth2 — Client ID público (no es secreto)
APP_GOOGLE_CLIENT_ID=<tu-google-client-id>.apps.googleusercontent.com

# AWS S3 — credenciales IAM (las de AWS Academy son temporales, rotar al expirar)
AWS_CREDENTIALS_ACCESS_KEY=<access-key>
AWS_CREDENTIALS_SECRET_KEY=<secret-key>
AWS_CREDENTIALS_SESSION_TOKEN=<session-token>
AWS_REGION_STATIC=us-east-1
AWS_S3_BUCKET=gamarra-360-s3
