# ============================================================
# Gamarra 360° — Variables de entorno para producción (EC2)
# Copiar a /opt/gamarra360/.env y completar los valores reales.
# El servicio systemd carga este archivo con EnvironmentFile=.
# ============================================================

# Base de datos (AWS RDS)
SPRING_DATASOURCE_URL=jdbc:mysql://ingechow.clsfbay9pwbr.us-east-1.rds.amazonaws.com:3306/gamarra360?useSSL=false&serverTimezone=America/Lima&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=adminadmin
SPRING_DATASOURCE_PASSWORD=<contraseña-rds>

# JPA — IMPORTANTE: usar validate en produccion, nunca update
JPA_DDL_AUTO=validate

# JWT — usar una clave larga y aleatoria en produccion
APP_JWT_SECRET=<clave-secreta-minimo-32-caracteres>

# Stripe
STRIPE_SECRET_KEY=sk_test_<tu-clave-secreta-stripe>
STRIPE_WEBHOOK_SECRET=whsec_<tu-webhook-secret-stripe>

# Google OAuth2
APP_GOOGLE_CLIENT_ID=1054501319788-fd9c67d26p5c2ne8qnvj5ltjarp2s5c3.apps.googleusercontent.com

# AWS S3 — credenciales IAM (renovar si son temporales de AWS Academy)
AWS_CREDENTIALS_ACCESS_KEY=<access-key>
AWS_CREDENTIALS_SECRET_KEY=<secret-key>
# AWS_CREDENTIALS_SESSION_TOKEN=<session-token>  # Solo si son credenciales temporales
AWS_REGION_STATIC=us-east-1
AWS_S3_BUCKET=gamarra-360-s3
